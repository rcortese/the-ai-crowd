TZ=America/Sao_Paulo

WORKBENCH_USER=operator
WORKBENCH_UID=1000
WORKBENCH_GID=1000

NODE_MAJOR=20
CLAUDE_CODE_VERSION=1.0.43
GEMINI_CLI_VERSION=0.1.18
CODEX_CLI_VERSION=0.26.0

STATE_DIR=./state/home
PROJECTS_DIR=./state/projects
REFERENCES_DIR=./state/references
SCRATCH_DIR=./state/scratch
SSH_DIR=./state/ssh

DOCKER_SOCKET=/var/run/docker.sock
DOCKER_GID=998

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Git uses the author values as the persistent shell defaults. If only one side
# is provided, the entrypoint mirrors it to the other pair; if both are set,
# their explicit values are preserved.
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=
